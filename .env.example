# EP Files — переменные окружения
# Скопируй этот файл в .env и заполни значения

# --- Django ---
SECRET_KEY=django-insecure-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# --- JWT ---
JWT_SECRET_KEY=super-secret-key-change-this-in-production
ACCESS_TOKEN_LIFETIME=900
REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_COOKIE_SECURE=False
JWT_COOKIE_SAMESITE=Lax

# --- Файлы ---
MAX_FILE_SIZE=104857600

# --- CORS (адрес фронтенда) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- База данных PostgreSQL ---
POSTGRES_DB=epfiles
POSTGRES_USER=epfiles
POSTGRES_PASSWORD=epfiles
DATABASE_URL=postgresql://epfiles:epfiles@db:5432/epfiles

# --- Суперпользователь (создаётся при первом запуске) ---
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin123
