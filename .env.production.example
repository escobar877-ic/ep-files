# EP Files production environment
# Copy to .env on the server and replace secrets/passwords.

DEBUG=False
SECRET_KEY=change-this-django-secret
JWT_SECRET_KEY=change-this-jwt-secret
LOG_LEVEL=INFO

ALLOWED_HOSTS=ep-files.ru,www.ep-files.ru,185.225.34.127,localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=https://ep-files.ru,https://www.ep-files.ru

ACCESS_TOKEN_LIFETIME=3600
MAX_FILE_SIZE=104857600

POSTGRES_DB=epfiles
POSTGRES_USER=epfiles
POSTGRES_PASSWORD=change-this-db-password
DATABASE_URL=postgresql://epfiles:change-this-db-password@db:5432/epfiles

DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-this-admin-password
